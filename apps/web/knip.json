{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreDependencies": [
    "@react-three/fiber",
    "camera-controls",
    "react-markdown",
    "remark-gfm",
    "@types/three",
    "three",
    "three-stdlib"
  ],
  "ignoreExportsUsedInFile": {
